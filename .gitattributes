# Normalize line endings. LF everywhere except Windows-only scripts, so the CI
# bash + python tooling runs correctly on Ubuntu/macOS runners.
* text=auto eol=lf

*.sh   text eol=lf
*.py   text eol=lf
*.dart text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf

*.ps1  text eol=crlf
*.bat  text eol=crlf

# Binaries
*.png  binary
*.jpg  binary
*.jpeg binary
*.jks  binary
*.keystore binary
